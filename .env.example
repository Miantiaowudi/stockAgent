# OpenAI API (可选)
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4

# Ollama 本地部署 (默认使用)
LLM_PROVIDER=ollama
LLM_MODEL=qwen2.5:14b
OLLAMA_BASE_URL=http://localhost:11434
LLM_TEMPERATURE=0.7

# LangChain
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=your_langchain_api_key_here

# Server
HOST=0.0.0.0
PORT=8000
DEBUG=true
